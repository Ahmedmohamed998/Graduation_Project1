# ── AI Service ───────────────────────────────────────────────────────────────

# Azure OpenAI
AZURE_OPENAI_API_KEY=your_azure_openai_api_key
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4-chat
AZURE_OPENAI_API_VERSION=2024-10-21

# MongoDB Atlas (same cluster as auth/home backends – for chat memory)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<appName>

# Azure Speech-to-Text
AZURE_SPEECH_KEY=your_azure_speech_key
AZURE_SPEECH_REGION=eastus2

# Azure Document Intelligence (OCR)
AZURE_DOC_INTEL_KEY=your_azure_doc_intel_key
AZURE_DOC_INTEL_ENDPOINT=https://<resource>.cognitiveservices.azure.com/
