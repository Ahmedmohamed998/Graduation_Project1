# ── Home Backend ─────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=production

# MongoDB Atlas (must be the SAME database as auth-backend)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<appName>

# JWT – must be the SAME secret as auth-backend
JWT_SECRET=your_strong_jwt_secret_here

# CORS – Flutter app origin
FRONTEND_URL=http://localhost:3210

# AI Agent – use service name when running in Docker Compose
AI_AGENT_URL=http://ai-service:8000

# Firebase – path inside the container (set by docker-compose volume mount)
FIREBASE_SERVICE_ACCOUNT_PATH=/app/firebase-adminsdk.json

# FCM notification threshold (local currency units)
FCM_LARGE_EXPENSE_THRESHOLD=500
