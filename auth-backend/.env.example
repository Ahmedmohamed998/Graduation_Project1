# ── Auth Backend ─────────────────────────────────────────────────────────────
PORT=3210
NODE_ENV=production

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<appName>

# JWT
JWT_SECRET=your_strong_jwt_secret_here
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d
USE_REFRESH_COOKIE=false

# CORS – set to your Flutter app's domain in production
CLIENT_URL=http://localhost:3210

# Email (Gmail app password)
EMAIL_USER=youremail@gmail.com
EMAIL_PASS=your_gmail_app_password

# Google OAuth (comma-separated for multi-platform)
GOOGLE_WEB_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_ANDROID_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_IDS=xxxx.apps.googleusercontent.com,xxxx.apps.googleusercontent.com

# Twilio SMS
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Phone verification
PHONE_VERIFICATION_JWT_SECRET=your_phone_verification_secret
PHONE_VERIFICATION_EXPIRE_MINUTES=10
SMS_RATE_LIMIT_SECONDS=60
SMS_CODE_EXPIRE_MINUTES=5

# Partner API
API_KEY=YourPartnerApiKey